# ── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ── DATABASE (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://imprsn8:password@localhost:5432/imprsn8
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-64-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── MFA ──────────────────────────────────────────────────
MFA_APP_NAME=imprsn8

# ── SOCIAL MEDIA API KEYS ────────────────────────────────

# X / Twitter (Pro tier)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# TikTok Research API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Instagram / Facebook Graph API
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN_2=
INSTAGRAM_ACCESS_TOKEN_3=
FACEBOOK_PAGE_TOKEN=

# YouTube Data API v3 (pool of 4 keys)
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=
YOUTUBE_API_KEY_4=

# LinkedIn (Partner Program)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=imprsn8-bot/1.0

# Threads (via Meta Graph API - shares IG quota)
THREADS_ACCESS_TOKEN=

# ── RATE GOVERNOR ────────────────────────────────────────
# Percentage of quota reserved for RECON/VERITAS reactive scans
QUOTA_RESERVE_PCT=20

# ── WATCHDOG ─────────────────────────────────────────────
WATCHDOG_ALERT_EMAIL=security@imprsn8.com
QUOTA_ALERT_THRESHOLD=90
